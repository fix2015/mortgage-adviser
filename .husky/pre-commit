#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔒 Running security checks..."

# Check for potential secrets in staged files
SECRETS_PATTERN='(sk_live|sk_test|AKIA[0-9A-Z]{16}|password\s*=\s*["\x27][^"\x27]+["\x27]|api[_-]?key\s*=\s*["\x27][^"\x27]+["\x27]|secret[_-]?key\s*=\s*["\x27][^"\x27]+["\x27])'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -n "$STAGED_FILES" ]; then
    # Check for secrets
    if echo "$STAGED_FILES" | xargs grep -lEi "$SECRETS_PATTERN" 2>/dev/null | grep -v '.example' | grep -v 'config.py' | grep -v '.md'; then
        echo "❌ SECURITY: Potential secrets found in staged files!"
        echo "Review the files above and remove any hardcoded credentials."
        exit 1
    fi

    # Check for .env files
    if echo "$STAGED_FILES" | grep -E '^\.env$|/\.env$|\.env\.local$'; then
        echo "❌ SECURITY: .env file is being committed!"
        exit 1
    fi

    # Check for .pem files
    if echo "$STAGED_FILES" | grep -E '\.pem$|\.key$'; then
        echo "❌ SECURITY: Private key file is being committed!"
        exit 1
    fi
fi

echo "✅ Security checks passed"

# Run frontend lint if frontend files changed
FRONTEND_FILES=$(echo "$STAGED_FILES" | grep '^frontend/' || true)
if [ -n "$FRONTEND_FILES" ]; then
    echo "📝 Running frontend lint..."
    cd frontend && npm run lint 2>/dev/null || echo "⚠️ Frontend lint skipped (npm not ready)"
    cd ..
fi

# Run backend lint if backend files changed
BACKEND_FILES=$(echo "$STAGED_FILES" | grep '^backend/' || true)
if [ -n "$BACKEND_FILES" ]; then
    echo "📝 Running backend lint..."
    cd backend && python -m ruff check . 2>/dev/null || echo "⚠️ Backend lint skipped (ruff not ready)"
    cd ..
fi
